---
// src/pages/index.astro
import BaseLayout from "../layouts/BaseLayout.astro";
import TopBar from "../components/TopBar.astro";
import NewHero from "../components/NewHero.astro";
import NewProjectLayout from '../layouts/NewProjectLayout.astro';
import CodeWindow from '../layouts/CodeWindow.astro';
import NewFooter from '../components/NewFooter.astro';
import ProjectsSelection from "../components/ProjectsSection.astro";
import Spacer from '../layouts/Spacer.astro';

// Node.js File System module to read raw code files at compile time
import fs from 'node:fs';
import path from 'node:path';

// --- Central Theme Strategy Injection ---
// Options: 'ocean' | 'sunset' | 'nordic' | 'github-dimmed' | 'amber' | 'emerald'
const currentTheme = 'gold-light-new'; // Set your desired theme here

// --- Safe External Markdown/Code file reading infrastructure ---
let k8sOperatorCode = `// Fallback: Kubernetes Operator Engine\nconsole.log("Syncing cluster state...");`;
let esp32FirmwareCode = `// Fallback: ESP32 OTA Client Loop\nvoid setup() { Serial.begin(115200); }`;
let unitySimulationCode = `// Fallback: Unity Real-Time Stream\nvoid Update() { IngestTelemetry(); }`;

try {
  // Resolving target directory paths inside your src/assets folder
  k8sOperatorCode = fs.readFileSync(path.resolve('./src/assets/code-files/esp32-operator.md'), 'utf-8');
  esp32FirmwareCode = fs.readFileSync(path.resolve('./src/assets/code-files/main.md'), 'utf-8');
  unitySimulationCode = fs.readFileSync(path.resolve('./src/assets/code-files/simulation.md'), 'utf-8');
} catch (error) {
  console.warn("Asset files not found yet. Using default string fallbacks for build processing.");
}

// --- Image Imports ---
import img1 from "../assets/Reference images/Proj_1.jpeg";
import img2 from "../assets/Reference images/Proj_2.jpeg";
import img3 from "../assets/Reference images/Proj_3.jpeg";

const projectImagesGroupA = [img1.src, img2.src, img3.src];
const projectImagesGroupB = [img2.src, img3.src, img1.src];
const projectImagesGroupC = [img3.src, img1.src, img2.src];
---

<BaseLayout theme={currentTheme}>

  <TopBar theme={currentTheme} />

  <NewHero theme={currentTheme} />

  <Spacer height="20vh" borderTop borderBottom />
  
  <ProjectsSelection theme={currentTheme} />

  <section id="projects" style="min-height: auto; padding: 6rem 2rem 0 2rem;">
    <div style="max-width: 800px; margin: 0 auto;">
      <h2 style="font-size: 3rem; font-weight: 800; letter-spacing: -0.05em; border-bottom: 2px solid var(--theme-primary, #38bdf8); padding-bottom: 0.75rem; margin: 0; color: var(--theme-text-heading, #f8fafc);">
        Selected Systems Architecture
      </h2>
    </div>
  </section>

  <NewProjectLayout 
    theme={currentTheme}
    title="Autonomous Embedded Firmware GitOps Pipeline" 
    time="3 Weeks" 
    bodyText="An automated infrastructure pipeline designed to bridge cloud-native orchestration with physical microcontrollers. This architecture treats edge hardware devices as traditional cluster resources, driving firmware version compliance state configurations deterministically."
    learned="Designed custom Kubernetes reconciliation controller loops capable of tracking version state maps and building conditional deployment models using structured messaging layers."
    more="Core Infrastructure Target Stack: Linux Edge Workers, k3s Control Planes, and isolated custom MQTT Broker configurations."
    images={projectImagesGroupA}
  />

  <CodeWindow 
    lang="python" code={k8sOperatorCode} 
    maxHeight="320px"
    fontSize="0.8rem"
    theme={currentTheme}
  >
    <h3 style="font-size: 1.75rem; color: var(--theme-text-heading, #f8fafc); margin-top: 0;">The Kubernetes Reconciliation Loop</h3>
    <p style="color: var(--theme-text-muted, #94a3b8); line-height: 1.6;">
      This backend orchestration layer acts as a custom state operator. It runs continuous observation windows against the MinIO binary storage bucket registries. 
      When a new hardware artifact payload matches strict schema rules, it constructs structural telemetry patches to enforce cluster state targets.
    </p>
    <ul style="color: var(--theme-text-muted, #94a3b8); padding-left: 1.25rem; margin: 1rem 0; line-height: 1.6;">
      <li>Automated artifact hash checking procedures.</li>
      <li>Stateless deployment tracking over active connections.</li>
      <li>Dynamic state variable payload generation.</li>
    </ul>
  </CodeWindow>

  <hr style="border: none; border-top: 1px solid var(--theme-border, #1e293b); margin: 4rem 0;" />

  <NewProjectLayout 
    theme={currentTheme}
    title="Distributed Edge Infrastructure Runtime" 
    time="1 Month" 
    bodyText="A resilient, hybrid multi-node k3s computing matrix designed to orchestrate application layers smoothly over diverse local architectures. The entire cluster states are declared completely declaratively, utilizing GitOps architectures for continuous configuration syncs."
    learned="Implemented rigorous overlay networks, managed private Tailscale mesh network parameters, and defined resource optimization configurations to handle system background load safely."
    more="Architectural Layout Metrics: Multi-Device Worker Deployments, automated Helm synchronization routines, and real-time internal service networking overlays."
    images={projectImagesGroupB}
  />

  <CodeWindow 
    lang="cpp" 
    code={esp32FirmwareCode} 
    maxHeight="500px" 
    fontSize="0.9rem" 
    codeOnRight={true}
    theme={currentTheme}
    startLine={10}
    endLine={25}
  >
    <h3 style="font-size: 1.75rem; color: var(--theme-text-heading, #f8fafc); margin-top: 0;">Hardware Over-The-Air Execution Engine</h3>
    <p style="color: var(--theme-text-muted, #94a3b8); line-height: 1.6;">
      On the physical endpoint tier, the client software uses persistent non-blocking socket loops to maintain responsive background sync communication frames. 
      This C++ runtime isolates hardware flash memory addresses to check firmware integrity safely before executing atomic updates.
    </p>
    <div style="background: var(--theme-bg-accent, rgba(56, 189, 248, 0.1)); border: 1px solid var(--theme-border, rgba(56, 189, 248, 0.2)); padding: 1rem; border-radius: 0.5rem; color: var(--theme-primary, #38bdf8); font-size: 0.95rem;">
      <strong>Edge Security Constraint Note:</strong> Intercepts network payloads with cryptographic keys, dropping unauthorized updates gracefully at the network boundary.
    </div>
  </CodeWindow>

  <hr style="border: none; border-top: 1px solid var(--theme-border, #1e293b); margin: 4rem 0;" />

  <NewProjectLayout 
    theme={currentTheme}
    title="Low-Latency Telemetry BCI Simulation Engine" 
    time="2 Months" 
    bodyText="A hardware-to-software rendering pipeline built to map high-frequency neural processing metrics directly into deep 3D interactive virtual spaces. Raw binary streaming signals are transformed via optimized thread pools into immediately applicable structural mechanics inside Unity."
    learned="Engineered high-velocity socket buffering abstractions in C# and minimized main-thread rendering freezes through custom asynchronous processing pools."
    more="Simulation Parameters: Asynchronous thread pools, physics update injection schedules, and high-frequency real-time graphing transformations."
    images={projectImagesGroupC}
  />

  <CodeWindow 
    lang="csharp" 
    code={unitySimulationCode}
    theme={currentTheme}
  >
    <h3 style="font-size: 1.75rem; color: var(--theme-text-heading, #f8fafc); margin-top: 0;">C# Physics Thread Synchronization</h3>
    <p style="color: var(--theme-text-muted, #94a3b8); line-height: 1.6;">
      This consumer engine runs completely decoupled from the main graphics frame loop. By reading incoming input streams into isolated memory blocks, 
      the framework avoids blocking game states and keeps movement computations matching real-world frequencies perfectly.
    </p>
    <pre style="background: var(--theme-code-bg, #020617); padding: 1rem; border-radius: 0.375rem; border: 1px solid var(--theme-border, #1e293b); font-family: monospace; font-size: 0.85rem; color: var(--theme-secondary, #64748b);">
// Target Network Operational Stream Metric
[Socket Pool Buffer Allocation: 2048 bytes] -> Asynchronous Dequeue -> Physics Loop Injection</pre>
  </CodeWindow>

  <NewFooter theme={currentTheme} />

</BaseLayout>