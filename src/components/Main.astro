<section class="hero">
	<div>
	<!--p>Page loaded in: <span id="load-time">0</span> ms</p-->
	  <h1 class="raj">Raj \</h1>
	  <h1 class="jeyaram"> &#8203 &#8203 &#8203 Jeyaram</h1>
	  <span class="slash">///</span> <span class="reg">Simulate</span> <span class="slash">/</span> <span class="reg">Orchestrate</span> <span class="slash">/</span> <span class="reg">Innovate</span>
	</div>
	<button id="scroll-btn" class="semi-arrow" ></button>
</section>

<style>
	.hero
	{
		font-family: var(--font-anton);
		background: radial-gradient(circle at 5% 5%, var(--radial-inner) 10%, var(--radial-middle) 30%, var(--radial-outer) 100%);

		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;

		height: 100vh;
	}

	.slash
	{
		color: var(--sunset);
		font-size: 1.5rem;
	}

	.reg
	{
		background: linear-gradient(160deg, var(--txt) 10%, var(--txt-end) 50%, var(--txt-end) 100%);

		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;

		font-size: 1.5rem;
		margin-top: -2em;
	}

	.hero h1
	{
		font-size: 20rem;
		margin-bottom: 0;

		background: linear-gradient(160deg, var(--txt) 0%, var(--txt-middle) 30%, var(--txt-end) 80%);

		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
	}

	.raj{
		margin-top: 0.03em;
	}

	.jeyaram{
		margin-top: -0.4em;
	}

	.hero p
	{
		background: linear-gradient(160deg, var(--txt) 10%, var(--txt-middle) 20%, var(--txt-middle) 100%);

		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;

		font-size: 1.5rem;
		margin-top: -2em;
		/*color: var(--txt);*/
	}




	/* Semicircle container */
    .semi-arrow {
      position: absolute;
      bottom: 0;
      left: 50%;
      transform: translateX(-50%);
      width: 200px;
      height: 150px;
	  background-color: rgba(255, 255, 255, 0); 
	 
      border-radius: 100px 100px 0 0;
		border: 3px solid var(--sun);
		border-bottom: none;
      display: flex;
      align-items: center;
      justify-content: center;

	  opacity: 0;
      animation: popUp 2s cubic-bezier(.98,0,.06,.96) forwards;
    }	

	.semi-arrow.hidden{
		animation: popDown 1s cubic-bezier(.98,0,.06,.96) forwards;
	}

	.semi-arrow:hover{
		transition: all 0.4s cubic-bezier(.77,.12,.16,.95);
		border: 3px solid var(--sun);
		border-bottom: none;
		color: var(--midnight);

	}
	.semi-arrow:active{
		transition: all 0.05s cubic-bezier(.77,.12,.16,.95);
		border: 20px solid var(--midnight);
		border-bottom: none;
		opacity: 1;
		background: var(--midnight);
		color: var(--black);

	}

    /* Arrow */
    .semi-arrow::before {
      content: "▼";
      color: var(--sunset);
      font-size: 70px;
      margin-top: 0.2em;
    }

	@keyframes popUp {
      0% {
        opacity: 0;
        transform: translateX(-50%) translateY(200px);
      } 

	  50% {
		backdrop-filter: blur(0px);
      -webkit-backdrop-filter: blur(0px);
		filter: blur(30px);
        opacity: 0;
        transform: translateX(-50%) translateY(200px);
      } 


      100% {
		backdrop-filter: blur(30px);
      -webkit-backdrop-filter: blur(30px);
		filter: blur(0px);
        opacity: 1;
        transform: translateX(-50%) translateY(0px);
      }
	}

	  @keyframes popDown {
      0% {
		backdrop-filter: blur(30px);
      -webkit-backdrop-filter: blur(30px);
		filter: blur(0px);
        opacity: 1;
        transform: translateX(-50%) translateY(0px);
      } 


      50% {
		backdrop-filter: blur(30px);
      -webkit-backdrop-filter: blur(30px);
		filter: blur(100px);
        opacity: 0;
        transform: translateX(-50%) translateY(200px);
      } 


      100% {
		opacity: 0;		
      }
	}
</style>

<script>
import { fade } from "astro:transitions";

	window.addEventListener('load', () => {
		// Get the first navigation entry
		const navigation = performance.getEntriesByType('navigation')[0] as PerformanceNavigationTiming;
	
		// Calculate total load time
		const loadTime = navigation
			? navigation.loadEventEnd.toFixed(2)
			: '0';
	
		// Display result
		document.getElementById('load-time')!.textContent = loadTime;
	});

	window.addEventListener('scroll', () => {

		const scrollTop = window.scrollY;
	 	if (scrollTop > 1) {
			document.querySelector('.semi-arrow')!.classList.add('hidden');
	  	} 
		else {
		document.querySelector('.semi-arrow')!.classList.remove('hidden');
	  }
	});

	const scrollBtn = document.getElementById('scroll-btn');
  scrollBtn?.addEventListener('click', () => {
    const vhPixels = window.innerHeight;
    window.scrollBy({
      top: vhPixels,
      behavior: "smooth"
    });
  });
</script>

