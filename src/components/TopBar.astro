---
// src/components/TopBar.astro

interface Props {
  theme?: string;
}

const { theme } = Astro.props;
---

<nav class="top-bar" data-theme={theme}>
  <a href="https://astro.ravijey.com" class="home">
    <span class="r">R</span><span class="full">aj Jeyaram</span>
  </a>
    
  <div class="social-grid-row">
    <div></div>
    
    <div class="social-col-center linkedin-wrapper">
      <a href="https://www.linkedin.com/in/rajvignesh-jeyaram-37a429241" class="linkedin">
        <span class="text-stack">
          <span class="initial">/solving</span>
          <span class="morph">
            <svg class="icon icon-linkedin" viewBox="0 0 24 24" fill="currentColor">
              <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
            </svg>
            LinkedIn
          </span>
        </span>
      </a>
    </div>
    
    <div class="social-col-right instagram-wrapper">
      <a href="https://instagram.com" class="instagram">
        <span class="text-stack">
          <span class="initial">/optimizing</span>
          <span class="morph">
            <svg class="icon icon-instagram" viewBox="0 0 24 24">
              <defs>
                <linearGradient id="insta-gradient" x1="100%" y1="100%" x2="0%" y2="0%">
                  <stop offset="0%" stop-color="#fccc63" />
                  <stop offset="5%" stop-color="#fccc63" />
                  <stop offset="25%" stop-color="#fbad50" />
                  <stop offset="45%" stop-color="#cd486b" />
                  <stop offset="65%" stop-color="#e95950" />
                  <stop offset="90%" stop-color="#8a3ab9" />
                  <stop offset="100%" stop-color="#4c68d7" />
                </linearGradient>
              </defs>
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
            <span class="text-instagram-gradient">Instagram</span>
          </span>
        </span>
      </a>
    </div>
  </div>
</nav>

<style>
  /* --- Variable Mapping to Global Tokens --- */
  .top-bar {
    --nav-primary: var(--theme-primary, #ff00ff);
    --nav-secondary: var(--theme-secondary, #ff00ff);
    --nav-bg: var(--theme-primary, #ff00ff);
    --nav-text: var(--theme-text-heading, #ff00ff);
    --nav-border: var(--theme-border, #ff00ff);

    z-index: 50;
    display: flex;
    position: absolute;
    
    top: 90vh;
    left: 0;
    right: 0;
    box-sizing: border-box;
    height: 5vh;

    opacity: 1;
    backdrop-filter: blur(0px);
    -webkit-backdrop-filter: blur(0px);
    border-bottom: 1px solid transparent;
    background-color: transparent;
    
    transition: 
      backdrop-filter 0.5s cubic-bezier(.98,0,.06,.96),
      background-color 0.5s cubic-bezier(.98,0,.06,.96),
      border-bottom 0.5s cubic-bezier(.98,0,.06,.96),
      opacity 0.5s cubic-bezier(.98,0,.06,.96),
      height 0.5s cubic-bezier(.98,0,.06,.96),
      background-color 0.5s cubic-bezier(.98,0,.06,.96);


    justify-content: space-between;
    align-items: center; 
    padding: 1rem 2rem;
  }

  /* Fixed State with Glassmorphism Theme Layering */
  .top-bar.active {
    position: fixed;
    top: 0;
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    /* Translated the old RGBA background to use color-mix for the new hex themes */
    background-color: color-mix(in srgb, var(--nav-bg) 10%, transparent); 
    border-bottom: 1px solid var(--nav-border);
  }

  .top-bar.active:hover{
    background-color: color-mix(in srgb, var(--nav-bg) 50%, transparent); 
    height: 25vh;
    transition: height 0.5s cubic-bezier(.98,0,.06,.96),
    background-color 0.5s cubic-bezier(.98,0,.06,.96);
  }

  /* Handle contextual color fallback overrides using inline browser fallback strings */
  [data-theme] .top-bar.active {
    background-color: transparent; /* Allows CSS backdrop filter vectors to bypass solid rules */
  }

  .top-bar a {
    text-decoration: none;
    font-family: var(--font-melo), monospace;
    font-size: 2rem;
    font-weight: 200;
    color: var(--theme-text-muted, #ff00ff);
  }
    
  .top-bar a.home {
    transform: translateX(10px);
    transition: all 0.5s cubic-bezier(.98,0,.06,.96);
  }

  .full {
    opacity: 0;
    transform: translateX(20vw);
    letter-spacing: -0.5em;
    filter: blur(6px);
    transition: all 0.5s cubic-bezier(.98,0,.06,.96);
  }

  .top-bar a.home.active {
    color: var(--nav-text);
    transform: translateX(20vw); 
    font-size: 1.5rem;
    font-weight: bold;
  }

  .top-bar a.home.active .full {
    opacity: 1;
    transform: translateX(0);
    letter-spacing: normal;
    font-size: 1.25rem;
    filter: blur(0);
  }

  .r {
    color: var(--nav-primary);
  }

  /* --- Grid Layout Engineering --- */
  .social-grid-row {
    position: absolute;
    left: 0;
    right: 0;
    padding: 0 2rem;
    box-sizing: border-box;
    
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    align-items: center;
    transition: all 0.5s cubic-bezier(.98,0,.06,.96);
  }

  .social-col-center {
    display: flex;
    justify-content: center;
    transition: all 0.5s cubic-bezier(.98,0,.06,.96);
  }

  .social-col-right {
    display: flex;
    justify-content: flex-end;
    transition: all 0.5s cubic-bezier(.98,0,.06,.96);
  }

  .top-bar.active .social-grid-row {
    overflow: visible;
  }

  /* --- Isolated Directional Shifts --- */
  .top-bar.active .linkedin-wrapper {
    transform: translateX(10vw); 
  }

  .top-bar.active .instagram-wrapper {
    transform: translateX(-20vw); 
  }

  .social-grid-row a {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    transition: all 0.5s cubic-bezier(.98,0,.06,.96);
  }

  .top-bar.active .social-grid-row a {
    font-size: 1.5rem;
  }

  /* --- Branding Specific Profiles --- */
  .social-grid-row a.linkedin .morph {
    color: #0077b5; 
  }

  .text-instagram-gradient {
    background: linear-gradient(45deg, #fccc63 0%, #fbad50 25%, #e95950 50%, #cd486b 75%, #8a3ab9 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  /* --- SVG Icon Engineering --- */
  .icon {
    width: 1.25em;
    height: 1.25em;
    display: inline-block;
    vertical-align: middle;
    margin-right: 0.4rem;
    flex-shrink: 0;
    opacity: 0;
    transform: scale(0.6) translateY(5px);
    transition: 
      transform 0.5s cubic-bezier(.98,0,.06,.96), 
      opacity 0.5s cubic-bezier(.98,0,.06,.96);
  }

  .icon-instagram {
    fill: url(#insta-gradient);
  }

  .top-bar.active .icon {
    opacity: 1;
    transform: scale(1) translateY(-1px);
  }

  /* --- Symmetrical Stack Locking Engine --- */
  .text-stack {
    position: relative;
    display: inline-grid;
    grid-template-columns: 1fr;
    align-items: center;
    justify-items: center; 
  }

  .social-col-right .text-stack {
    justify-items: end;
  }

  .social-grid-row .initial,
  .social-grid-row .morph {
    grid-area: 1 / 1; 
    white-space: nowrap;
    display: inline-flex;
    align-items: center;
    transition: 
      transform 0.5s cubic-bezier(.98,0,.06,.96), 
      opacity 0.5s cubic-bezier(.98,0,.06,.96),
      filter 0.5s cubic-bezier(.98,0,.06,.96);
  }

  .social-grid-row .initial {
    color: var(--nav-primary);
    opacity: 1;
    transform: translateX(0);
    filter: blur(0);
    /* Injected monospace font specifically for the pre-morph tags */
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 1.25rem;
  }

  .social-grid-row .morph {
    opacity: 0;
    transform: translateX(20px);
    filter: blur(4px);
    color: var(--theme-text-muted, #ff00ff);
    font-size: 1.25rem;
  }

  .top-bar.active .social-grid-row .initial {
    opacity: 0;
    transform: translateX(-20px);
    filter: blur(4px);
  }

  .top-bar.active .social-grid-row .morph {
    opacity: 1;
    transform: translateX(0);
    filter: blur(0);
  }
</style>

<script>
  const home = document.querySelector('.home');
  const topBar = document.querySelector('.top-bar');

  window.addEventListener('scroll', () => {
    const scrollPercent = (window.scrollY / window.innerHeight) * 100;

    if (scrollPercent >= 90) {
      home?.classList.add('active');
      topBar?.classList.add('active');
    } else {
      home?.classList.remove('active');
      topBar?.classList.remove('active');
    }
  }, { passive: true });
</script>