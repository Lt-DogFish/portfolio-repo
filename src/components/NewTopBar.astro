---
// src/components/NewTopBar.astro
---
<nav class="topbar">
  <div class="nav-container">
    <a href="#about" class="logo">Portfolio</a>
    <div class="nav-links">
      <a href="#about">About</a>
      <a href="#projects">Projects</a>
    </div>
  </div>
</nav>

<style>
  .topbar {
    position: fixed;
    top: 0;
    width: 100%;
    background: rgba(15, 23, 42, 0.9);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid #1e293b;
    z-index: 100;
    padding: 1rem 0;
  }
  .nav-container {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    padding: 0 2rem;
    box-sizing: border-box;
  }
  .logo {
    color: #38bdf8;
    text-decoration: none;
    font-weight: bold;
  }
  .nav-links {
    display: flex;
    gap: 1.5rem;
  }
  .nav-links a {
    color: #94a3b8;
    text-decoration: none;
    transition: color 0.2s;
  }
  .nav-links a:hover {
    color: #38bdf8;
  }
</style>