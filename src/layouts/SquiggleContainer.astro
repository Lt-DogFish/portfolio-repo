---
// SquiggleContainer.astro
declare global {
  interface Window {
    SquiggleManager: {
      register:   (cfg: any)   => void;
      unregister: (id: string) => void;
    };
    __pendingSquiggles: any[];
  }

  // 1. Define the props structure
interface SquiggleProps {
  instanceCount: number;
  viewport: [number, number];
  scrollY: number;
  canvasW: number;
  canvasH: number;
}
}
---

<canvas id="global-squiggle-canvas"></canvas>

<script>
  import createRegl from "regl";

  (() => {
    if (window.SquiggleManager) return;

    const canvas = document.getElementById("global-squiggle-canvas") as HTMLCanvasElement;
    
    // Let Regl create the context. We explicitly request the instancing extension.
    const regl = createRegl({
      canvas: canvas,
      extensions: ['ANGLE_instanced_arrays'],
      attributes: {
        antialias: true,
        premultipliedAlpha: true,
        alpha: true,
      }
    });

    if (!regl) { console.warn("Regl initialization failed, squiggles disabled"); return; }

    // ─── Config ───────────────────────────────────────────────────────────────
    const CONFIG = {
      curveMultiplier: 1.5,
      loopVolumePush:  0.3,
      cullMargin:      400,
      segments:        48,
      strokeWidth:     2.0,
    };

    const VERTS_PER_PATH = (CONFIG.segments + 1) * 2;
    const FLOATS_PER_INSTANCE = 16;
    const BYTES_PER_INSTANCE = FLOATS_PER_INSTANCE * 4;

    // ─── Shaders (Converted to standard GLSL 100 for Regl compatibility) ──────
    const VS = `
    precision highp float;

    attribute float a_t;        
    attribute float a_side;     

    attribute vec2  a_p0;
    attribute vec2  a_p1;
    attribute vec2  a_p2;
    attribute vec2  a_p3;
    attribute vec4  a_color;
    attribute vec4  a_params;   

    uniform vec2 u_viewport;   
    uniform float u_scrollY;

    varying vec4  v_color;
    varying float v_t;
    varying vec4  v_params;
    varying float v_arcLen;       

    vec2 bezier(float t) {
      float u = 1.0 - t;
      return u*u*u*a_p0 + 3.0*u*u*t*a_p1 + 3.0*u*t*t*a_p2 + t*t*t*a_p3;
    }
    vec2 bezierDeriv(float t) {
      float u = 1.0 - t;
      return 3.0*u*u*(a_p1-a_p0) + 6.0*u*t*(a_p2-a_p1) + 3.0*t*t*(a_p3-a_p2);
    }

    void main() {
      vec2  p   = bezier(a_t);
      vec2  d   = bezierDeriv(a_t);
      vec2  n   = normalize(vec2(-d.y, d.x));
      float w   = a_params.x * 0.5;

      p += n * w * a_side;

      vec2 px = p - vec2(0.0, u_scrollY);
      vec2 clip = (px / u_viewport) * 2.0 - 1.0;
      clip.y = -clip.y;
      gl_Position = vec4(clip, 0.0, 1.0);

      v_color  = a_color;
      v_t      = a_t;
      v_params = a_params;
      v_arcLen = a_t * length(a_p3 - a_p0) * 1.2;
    }`;

    const FS = `
    precision highp float;

    varying vec4  v_color;
    varying float v_t;
    varying vec4  v_params;   
    varying float v_arcLen;

    void main() {
      if (v_t > v_params.y) discard;

      if (v_params.z > 0.0) {
        float cycle = mod(v_arcLen + v_params.w, v_params.z * 2.0);
        if (cycle > v_params.z) discard;
      }

      gl_FragColor = v_color;
    }`;

    // ─── Regl Setup ───────────────────────────────────────────────────────────
    
    const templateT = new Float32Array(VERTS_PER_PATH);
    const templateSide = new Float32Array(VERTS_PER_PATH);
    for (let i = 0; i <= CONFIG.segments; i++) {
      templateT[i*2] = templateT[i*2+1] = i / CONFIG.segments;
      templateSide[i*2] = -1; templateSide[i*2+1] = +1;
    }

    // Dynamic buffer for instances
    const instanceBuf = regl.buffer({ type: 'float', usage: 'dynamic', length: 0 });

    const drawSquiggles = regl<SquiggleProps>({
      vert: VS,
      frag: FS,

      // ADD THIS BLOCK: Force WebGL to use the full resized canvas buffer
      viewport: {
        x: 0,
        y: 0,
        width: regl.prop<SquiggleProps, 'canvasW'>('canvasW'),
        height: regl.prop<SquiggleProps, 'canvasH'>('canvasH')
      },

      attributes: {
        a_t: regl.buffer(templateT),
        a_side: regl.buffer(templateSide),
        
        a_p0:    { buffer: instanceBuf, divisor: 1, offset: 0,  stride: BYTES_PER_INSTANCE },
        a_p1:    { buffer: instanceBuf, divisor: 1, offset: 8,  stride: BYTES_PER_INSTANCE },
        a_p2:    { buffer: instanceBuf, divisor: 1, offset: 16, stride: BYTES_PER_INSTANCE },
        a_p3:    { buffer: instanceBuf, divisor: 1, offset: 24, stride: BYTES_PER_INSTANCE },
        a_color: { buffer: instanceBuf, divisor: 1, offset: 32, stride: BYTES_PER_INSTANCE },
        a_params:{ buffer: instanceBuf, divisor: 1, offset: 48, stride: BYTES_PER_INSTANCE },
      },

// FIX: Explicitly define uniforms and cast the values to satisfy TS
// We define the uniforms object and explicitly allow any string key 
// without forcing the props to be keys of the uniform object.
uniforms: {
  'u_viewport': regl.prop<SquiggleProps, 'viewport'>('viewport'),
  'u_scrollY':  regl.prop<SquiggleProps, 'scrollY'>('scrollY')
} as any, // This bypasses the overly-strict internal validation

      depth: { enable: false },
      blend: {
        enable: true,
        func: {
          srcRGB: 'one', dstRGB: 'one minus src alpha',
          srcAlpha: 'one', dstAlpha: 'one minus src alpha'
        }
      },

      primitive: 'triangle strip',
      count: VERTS_PER_PATH,
      instances: regl.prop<SquiggleProps, 'instanceCount'>('instanceCount')
    });

    // ─── State & Helpers ──────────────────────────────────────────────────────
    let vpW = window.innerWidth, vpH = window.innerHeight, vpScrollY = window.scrollY;
    let dpr = Math.min(window.devicePixelRatio || 1, 2);

    const squiggles = new Map<string, any>();
    let instanceData = new Float32Array(0);
    let instanceCount = 0;
    let dirty = true;

    function parseColor(): [number, number, number, number] {
      const css = getComputedStyle(document.documentElement).getPropertyValue("--theme-primary").trim() || "#ff00ff";
      if (css.startsWith("#")) {
        const hex = css.slice(1);
        const n = parseInt(hex.length === 3 ? hex.split("").map(c => c+c).join("") : hex, 16);
        return [((n>>16)&255)/255, ((n>>8)&255)/255, (n&255)/255, 1];
      }
      const m = css.match(/\d+(\.\d+)?/g);
      if (m) return [+m[0]/255, +m[1]/255, +m[2]/255, m[3] ? +m[3] : 1];
      return [1, 0, 1, 1];
    }
    
    let themeColor = parseColor();
    function vh(v: number) { return (vpH * v) / 100; }

    function computeControlPoints(cfg: any) {
      const top = vh(cfg.windowLocation), height = vh(cfg.windowHeight);
      const width = vpW, upward = cfg.startDirection === "up";

      const p0x = (cfg.start / 100) * width, p0y = top + (upward ? height : 0);
      const p3x = (cfg.end / 100) * width,   p3y = top + (upward ? 0 : height);

      const intensity = (cfg.waviness / 100) * CONFIG.curveMultiplier;
      let p1x = p0x, p1y = p0y, p2x = p3x, p2y = p3y;

      if (cfg.startDirection === "down") p1y += height * intensity;
      if (cfg.startDirection === "up")   p1y -= height * intensity;
      if (cfg.startDirection === "left") p1x -= width  * intensity;
      if (cfg.startDirection === "right")p1x += width  * intensity;
      if (cfg.endDirection === "down")   p2y -= height * intensity;
      if (cfg.endDirection === "up")     p2y += height * intensity;
      if (cfg.endDirection === "left")   p2x += width  * intensity;
      if (cfg.endDirection === "right")  p2x -= width  * intensity;

      if (cfg.shouldLoop) {
        const tx = p1x; p1x = p2x; p2x = tx;
        p1y += height * intensity * CONFIG.loopVolumePush;
        p2y -= height * intensity * CONFIG.loopVolumePush;
      }
      return { p0x, p0y, p1x, p1y, p2x, p2y, p3x, p3y };
    }

    function dashScaleFor(style: string): number {
      switch (style) {
        case "dashed": return 16;
        case "dotted": return 2; 
        default:       return 0;
      }
    }

    // ─── Buffer Rebuild & Render Loop ─────────────────────────────────────────
    function rebuildInstances(time: number) {
      const top = vpScrollY - CONFIG.cullMargin;
      const bottom = vpScrollY + vpH + CONFIG.cullMargin;

      let visible = 0;
      squiggles.forEach((cfg) => {
        const pt = vh(cfg.windowLocation);
        const pb = pt + vh(cfg.windowHeight);
        cfg._visible = pb > top && pt < bottom;
        if (cfg._visible) visible++;
      });

      if (instanceData.length < visible * FLOATS_PER_INSTANCE) {
        instanceData = new Float32Array(visible * FLOATS_PER_INSTANCE * 2);
      }

      let i = 0;
      squiggles.forEach((cfg) => {
        if (!cfg._visible) return;

        const cp = computeControlPoints(cfg);
        if (cfg._drawStart == null) cfg._drawStart = time;
        const drawDurMs = (parseFloat(cfg.duration) || 1) * 1000;
        const progress  = Math.min(1, (time - cfg._drawStart) / drawDurMs);

        const dashScale = dashScaleFor(cfg.lineStyle);
        let dashOffset = 0;
        if (cfg.isRolling && dashScale > 0) {
          const rollDurMs = (parseFloat(cfg.rollDuration) || 1) * 1000;
          dashOffset = -((time % rollDurMs) / rollDurMs) * 16;
        }

        const o = i * FLOATS_PER_INSTANCE;
        instanceData[o+0] = cp.p0x; instanceData[o+1] = cp.p0y;
        instanceData[o+2] = cp.p1x; instanceData[o+3] = cp.p1y;
        instanceData[o+4] = cp.p2x; instanceData[o+5] = cp.p2y;
        instanceData[o+6] = cp.p3x; instanceData[o+7] = cp.p3y;
        instanceData[o+8] = themeColor[0]; instanceData[o+9] = themeColor[1];
        instanceData[o+10]= themeColor[2]; instanceData[o+11]= themeColor[3];
        instanceData[o+12]= CONFIG.strokeWidth;
        instanceData[o+13]= progress;
        instanceData[o+14]= dashScale;
        instanceData[o+15]= dashOffset;
        i++;
      });

      instanceCount = visible;
      
      // Pass only the exact active subarray to prevent uploading trailing zeros
      instanceBuf({ data: instanceData.subarray(0, instanceCount * FLOATS_PER_INSTANCE) });
    }

    function resizeCanvas() {
      vpW = window.innerWidth; vpH = window.innerHeight;
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      canvas.width = vpW * dpr; canvas.height = vpH * dpr;
      canvas.style.width = vpW + "px"; canvas.style.height = vpH + "px";
    }

    let animating = false;
    function anyAnimating(time: number): boolean {
      let active = false;
      squiggles.forEach((cfg) => {
        if (!cfg._visible) return;
        if (cfg.isRolling && dashScaleFor(cfg.lineStyle) > 0) { active = true; return; }
        if (cfg._drawStart != null) {
          const dur = (parseFloat(cfg.duration) || 1) * 1000;
          if (time - cfg._drawStart < dur) active = true;
        }
      });
      return active;
    }

    function frame(time: number) {
      vpScrollY = window.scrollY; 

      if (dirty || animating) {
        rebuildInstances(time);
        dirty = false;
      }

      regl.clear({ color: [0, 0, 0, 0], depth: 1 });

      if (instanceCount > 0) {
        drawSquiggles({
          instanceCount: instanceCount,
          viewport: [vpW, vpH], // Fix: Passed CSS pixels instead of DPR-scaled values
          scrollY: vpScrollY,   // Fix: Kept scrollY matching 1:1 with CSS pixels
          canvasW: canvas.width,  // Add this
          canvasH: canvas.height  // Add this
        });
      }

      animating = anyAnimating(time);
      if (animating || dirty) requestAnimationFrame(frame);
      else renderingScheduled = false;
    }

    let renderingScheduled = false;
    function scheduleRender() {
      if (renderingScheduled) return;
      renderingScheduled = true;
      requestAnimationFrame(frame);
    }
    function markDirty() {
      dirty = true;
      scheduleRender();
    }

    // ─── Events ───────────────────────────────────────────────────────────────
    let resizeTimer = -1;
    window.addEventListener("resize", () => {
      clearTimeout(resizeTimer);
      resizeTimer = window.setTimeout(() => { resizeCanvas(); markDirty(); }, 150);
    });

    let scrollPending = false;
    window.addEventListener("scroll", () => {
      if (scrollPending) return;
      scrollPending = true;
      requestAnimationFrame(() => {
        vpScrollY = window.scrollY;
        markDirty();
        scrollPending = false;
      });
    }, { passive: true });

    const themeObserver = new MutationObserver(() => {
      themeColor = parseColor(); markDirty();
    });
    themeObserver.observe(document.documentElement, {
      attributes: true, attributeFilter: ["class", "data-theme", "style"],
    });

    // ─── Public API ───────────────────────────────────────────────────────────
    window.SquiggleManager = {
      register(cfg) {
        squiggles.set(cfg.id, { ...cfg, _drawStart: null, _visible: false });
        markDirty();
      },
      unregister(id) {
        squiggles.delete(id); markDirty();
      },
    };

    (window.__pendingSquiggles ?? []).forEach((cfg) => window.SquiggleManager.register(cfg));
    window.__pendingSquiggles = [];

    resizeCanvas(); markDirty();
  })();
</script>

<style is:global>
  #global-squiggle-canvas {
    position: fixed; inset: 0;
    width: 100vw; height: 100vh;
    pointer-events: none; z-index: 100;
  }
</style>