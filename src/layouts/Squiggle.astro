---
interface Props {
  id: string;
  
  duration?: string;
  
  windowLocation?: number;
  windowHeight?: number;
  
  start?: number;
  end?: number;
  
  startDirection?:
  | "down"
  | "left"
  | "right"
  | "up";
  
  endDirection?:
  | "down"
  | "left"
  | "right"
  | "up";
  
  waviness?: number;
  
  shouldLoop?: boolean;
  
  lineStyle?:
  | "solid"
  | "dashed"
  | "dotted";
  
  markerType?:
  | "arrow"
  | "circle"
  | "square"
  | "none";
  
  isRolling?: boolean;
  
  rollDuration?: string;
  }
  
  const {
  id,
  
  duration = "3",
  
  windowLocation = 0,
  windowHeight = 100,
  
  start = 10,
  end = 90,
  
  startDirection = "down",
  endDirection = "down",
  
  waviness = 50,
  
  shouldLoop = false,
  
  lineStyle = "solid",
  
  markerType = "arrow",
  
  isRolling = false,
  
  rollDuration = "1s"
  } = Astro.props;
  ---
  
  <script
  define:vars={{
  id,
  duration,
  windowLocation,
  windowHeight,
  start,
  end,
  startDirection,
  endDirection,
  waviness,
  shouldLoop,
  lineStyle,
  markerType,
  isRolling,
  rollDuration
  }}
  >
  
  const config = {
  id,
  duration,
  
  windowLocation,
  windowHeight,
  
  start,
  end,
  
  startDirection,
  endDirection,
  
  waviness,
  
  shouldLoop,
  
  lineStyle,
  
  markerType,
  
  isRolling,
  
  rollDuration
  };
  
  window.__pendingSquiggles ??= [];
  
  if (window.SquiggleManager) {
  window.SquiggleManager.register(config);
  } else {
  window.__pendingSquiggles.push(config);
  }
  
  window.addEventListener(
  "beforeunload",
  () => {
  window.SquiggleManager
  ?.unregister(id);
  },
  { once:true }
  );
  
  </script>