---
// src/layouts/BaseLayout.astro
import { Font } from "astro:assets";
import "../styles/global.css";

interface Props {
  theme?: string;
}

const { theme } = Astro.props;
---

<html lang="en" data-theme={theme}>
  <Font cssVariable="--font-melo" preload />
  <Font cssVariable="--font-anton" preload />
  <Font cssVariable="--font-bebas" preload />
  <Font cssVariable="--font-fanwood" preload />
  <Font cssVariable="--font-spartan" preload />
  <Font cssVariable="--font-newtitle" preload />
  <Font cssVariable="--font-satoshi" preload />
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link 
      rel="stylesheet" 
      href="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/themes/prism-tomorrow.min.css" 
    />
    <title>Continuous Portfolio</title>
    <style is:global>
      html {
        scroll-behavior: smooth;
        font-family: system-ui, sans-serif;
        
        /* Now properly tracks the variables mapped in your global.css selectors */
        background-color: var(--theme-site-bg, transparent); 
        color: var(--theme-text-heading, inherit);
        
        transition: background-color 0.4s cubic-bezier(.77,.12,.16,.95),
                    color 0.4s cubic-bezier(.77,.12,.16,.95);
      }
      body { margin: 0; padding: 0; }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>