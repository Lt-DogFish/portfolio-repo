---
// src/layouts/CodeWindow.astro
import { Prism } from '@astrojs/prism';

interface Props {
  code: string;
  lang: string;
  codeOnRight?: boolean;
  maxHeight?: string;
  fontSize?: string;
  theme?: string;
  
  // Line Focusing Props
  startLine?: number; 
  endLine?: number;   
}

const { 
  code, 
  lang, 
  codeOnRight = false, 
  maxHeight = "450px", 
  fontSize = "0.9rem",   
  theme,
  startLine,
  endLine
} = Astro.props;

const isFocusMode = startLine !== undefined && endLine !== undefined;
---

<section class="code-section" data-theme={theme}>
  <div class={`glow-backdrop ${codeOnRight ? 'glow-right' : 'glow-left'}`}></div>

  <div 
    class={`split-container ${codeOnRight ? 'row-reverse' : ''} ${isFocusMode ? 'has-line-focus' : ''}`} 
    style={`
      --editor-max-height: ${maxHeight}; 
      --editor-font-size: ${fontSize};
    `}
  >
    <div class="text-column">
      <slot />
    </div>

    <div class="code-column">
      <div class="mac-window">
        <div class="window-header">
          <div class="dots">
            <span class="dot close"></span>
            <span class="dot minimize"></span>
            <span class="dot expand"></span>
          </div>
          <span class="window-title">runtime.{lang === 'cpp' ? 'cpp' : lang === 'csharp' ? 'cs' : lang}</span>
        </div>
        
        <div class="code-scroll-pane">
          <Prism lang={lang} code={code} />
        </div>
      </div>
    </div>
  </div>
</section>

{isFocusMode && (
  <style is:global define:vars={{ startLine, endLine }}>
    .has-line-focus .code-scroll-pane pre [class*="token"] {
      opacity: 0.25 !important;
      filter: grayscale(80%) !important;
      transition: opacity 0.3s ease;
    }
  </style>
)}

<style>
  /* ------------------------------------------------------------------
     Theme Tokens Mapping Definitions
     ------------------------------------------------------------------ */
  .code-section {
    --window-accent: var(--theme-primary, #ff00ff);
    --window-border: var(--theme-code-border, #ff00ff);
    --window-bg: var(--theme-code-bg, #ff00ff);
    --glow-color: color-mix(in srgb, var(--radial-inner, #ff00ff) 40%, transparent);
    
    background-color: var(--theme-site-bg, #ff00ff);
    width: 100%;
    position: relative;
    overflow: hidden;
  }

  /* --- Ambient Light Prototyping System --- */
  .glow-backdrop {
    position: absolute;
    top: 50%;
    width: 1200px;
    height: 1200px;
    transform: translateY(-50%);
    pointer-events: none;
    z-index: 0;
    mix-blend-mode: screen;
    opacity: 0.85;
    background: radial-gradient(
      circle, 
      var(--glow-color) 0%, 
      transparent 70%
    );
    transition: left 0.3s ease, right 0.3s ease;
  }

  /* Moves focal node dynamically depending on structural split configuration shifts */
  .glow-left {
    right: -250px;
    left: auto;
  }

  .glow-right {
    left: -250px;
    right: auto;
  }

  @media (min-width: 1200px) {
    .glow-left {
      right: 5%;
    }
    .glow-right {
      left: 5%;
    }
  }

  /* Split layout mechanics structural stack adjustments */
  .split-container { 
    display: flex; 
    flex-direction: column; 
    gap: 2.5rem; 
    width: 100%;
    max-width: 90%;        
    margin: 4rem auto;       
    padding: 2rem 2rem;         
    box-sizing: border-box;  
    position: relative;
    z-index: 1;
  }

  @media (min-width: 768px) {
    .split-container { 
      flex-direction: row; 
      gap: 4rem; 
      align-items: center; 
    }
    .text-column, .code-column { 
      flex: 1; 
      width: 50%; 
    }
    .row-reverse { 
      flex-direction: row-reverse; 
    }
  }

  .text-column {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 0; 
  }

  /* IDE Window Base Styles */
  .mac-window {
    background-color: var(--window-bg);
    border: 1px solid var(--window-border);
    border-radius: 0.75rem;
    box-shadow: 0 25px 50px -12px color-mix(in srgb, var(--theme-card-shadow, #ff00ff) 50%, transparent);
    overflow: hidden;
    width: 100%;
    transition: border-color 0.3s ease;
    backdrop-filter: blur(8px); /* Subtle edge integration layer enhancement */
  }

  .mac-window:hover {
    border-color: var(--window-accent);
  }

  .window-header { 
    background-color: var(--window-bg); 
    filter: brightness(1.15); 
    padding: 0.75rem 1rem; 
    display: flex; 
    justify-content: space-between; 
    align-items: center;
    border-bottom: 1px solid var(--window-border);
  }
  
  .dots { display: flex; gap: 0.4rem; }
  .dot { width: 10px; height: 10px; border-radius: 50%; display: inline-block; }
  .close { background: #ff5f56; } 
  .minimize { background: #ffbd2e; } 
  .expand { background: #27c93f; }
  .window-title { font-family: ui-monospace, monospace; font-size: 0.8rem; color: var(--theme-text-muted, #ff00ff); }

  /* Controlled Scroll Pane Box */
  .code-scroll-pane {
    max-height: var(--editor-max-height);
    overflow-y: auto !important; 
    overflow-x: auto !important; 
    background-color: var(--window-bg) !important;
  }

  .has-line-focus .code-scroll-pane {
    mask-image: linear-gradient(
      to bottom,
      rgba(0,0,0,0.3) 0%,      
      rgba(0,0,0,1.0) 25%,     
      rgba(0,0,0,1.0) 75%,     
      rgba(0,0,0,0.3) 100%     
    );
    -webkit-mask-image: linear-gradient(
      to bottom,
      rgba(0,0,0,0.2) 0%,
      rgba(0,0,0,1.0) 20%,
      rgba(0,0,0,1.0) 80%,
      rgba(0,0,0,0.2) 100%
    );
  }

  /* --- FORCE OVERRIDE PRISM INTERNAL GENERATED TARGETS --- */
  .code-scroll-pane :global(pre),
  .code-scroll-pane :global(pre[class*="language-"]) { 
    max-height: var(--editor-max-height) !important;
    margin: 0 !important; 
    padding: 1.5rem !important; 
    background: transparent !important; 
    overflow: visible !important; 
  }

  .code-scroll-pane :global(code),
  .code-scroll-pane :global(code[class*="language-"]) {
    color: var(--theme-code-text, inherit);
    font-size: var(--editor-font-size) !important;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace !important;
    line-height: 1.5 !important;
    background: transparent !important;
  }

  /* --- Custom Themed Scrollbar Configuration Track --- */
  .code-scroll-pane::-webkit-scrollbar {
    width: 8px;
    height: 8px;
  }
  .code-scroll-pane::-webkit-scrollbar-track {
    background: var(--window-bg);
  }
  .code-scroll-pane::-webkit-scrollbar-thumb {
    background: var(--window-border);
    border-radius: 4px;
    border: 1px solid var(--window-border);
  }
  .code-scroll-pane::-webkit-scrollbar-thumb:hover {
    background: var(--window-accent);
  }
</style>